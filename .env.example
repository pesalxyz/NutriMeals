# Shared defaults
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nutriscan
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
API_PORT=4000
WEB_URL=http://localhost:3000
MOBILE_APP_SCHEME=nutriscan
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=apps/api/uploads
# AI provider: heuristic | openai | mock_fixed
AI_PROVIDER=heuristic
# OpenAI-compatible LLM settings (supports custom providers/endpoints)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_VISION_MODEL=
LLM_NUTRITION_MODEL=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
PUBLIC_API_RATE_LIMIT_PER_MINUTE=10
