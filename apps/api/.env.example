NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nutriscan
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
WEB_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_IDS=your_web_client_id.apps.googleusercontent.com,your_android_client_id.apps.googleusercontent.com
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=apps/api/uploads
AI_PROVIDER=auto
# OpenAI-compatible LLM settings (supports custom providers, e.g. MiniMax/OpenRouter compatible endpoints)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_VISION_MODEL=
LLM_NUTRITION_MODEL=
# Backward-compatible OpenAI vars
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_NUTRITION_MODEL=gpt-4.1-mini
SCAN_LEGACY_COMPONENT_FALLBACK=false
PUBLIC_API_RATE_LIMIT_PER_MINUTE=10
